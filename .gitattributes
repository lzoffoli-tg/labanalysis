# Git attributes for labanalysis

# Mark test data files as binary (don't diff)
*.tdf binary
*.c3d binary

# Mark large test assets as LFS candidates (optional)
# test/assets/**/*.tdf filter=lfs diff=lfs merge=lfs -text

# Python files
*.py text eol=lf

# Documentation
*.md text eol=lf
*.rst text eol=lf

# Configuration files
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.ini text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
