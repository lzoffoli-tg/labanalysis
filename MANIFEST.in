# Include essential files in source distribution
include README.md
include LICENSE
include pyproject.toml
include setup.py

# Include source code
recursive-include src *.py

# Exclude test directory from built distributions
# Tests are only available when installing in dev mode
exclude test
recursive-exclude test *

# Exclude development and build artifacts
recursive-exclude * __pycache__
recursive-exclude * *.py[co]
recursive-exclude * .pytest_cache
recursive-exclude * .coverage
recursive-exclude * *.egg-info

# Exclude IDE and editor files
recursive-exclude * .vscode
recursive-exclude * .idea
recursive-exclude * *.swp
recursive-exclude * *.swo
recursive-exclude * *~

# Exclude documentation build artifacts
recursive-exclude docs/_build *
